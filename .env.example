# Exam Display Configuration

# Timezone for the exam display
# Use IANA timezone identifiers (e.g., 'Asia/Jakarta', 'America/New_York', 'Europe/London', 'UTC')
# Default: UTC (if not specified)
TIMEZONE=UTC

# NTP server is enforced in the application code as ntp.ui.ac.id.
# This variable is ignored and kept only for backward compatibility with older deployments.
NTP_SERVER=ntp.ui.ac.id

# Application Port (for development)
# Default: 3000 (Vite will use 5173+ for dev server)
PORT=3000

# Node Environment
NODE_ENV=production
